    {
      "name": "03 - Get Cart - Positive Tests",
      "item": [
        {
          "name": "TC009 - Get Cart with Items",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Cart contains items', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.items).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Each item has required fields', function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.items.length > 0) {",
                  "        var item = jsonData.items[0];",
                  "        pm.expect(item).to.have.property('id');",
                  "        pm.expect(item).to.have.property('productId');",
                  "        pm.expect(item).to.have.property('productName');",
                  "        pm.expect(item).to.have.property('price');",
                  "        pm.expect(item).to.have.property('quantity');",
                  "        pm.expect(item).to.have.property('subtotal');",
                  "    }",
                  "});",
                  "",
                  "pm.test('Total price is calculated correctly', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.totalPrice).to.be.a('number');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
