    "name": "Shopping Cart API Test Collection",
    "description": "Comprehensive API test collection for Shopping Cart application (SCRUM-11692)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "shopping-cart-api-tests",
